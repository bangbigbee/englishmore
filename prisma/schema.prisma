// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  user    // Người dùng mới đăng ký, chưa là học viên
  member  // Học viên/member đã đăng ký khóa học
  admin   // Quản trị viên
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  method        String?      // PPF, Beyond, Contrast
  role          UserRole     @default(user) // user, member, or admin
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now())
  accounts      Account[]
  sessions      Session[]
  assignments   Assignment[]
  enrollments   Enrollment[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assignment {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  filePath    String?
  method      String   // PPF, Beyond, Contrast
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id                   String       @id @default(cuid())
  title                String
  description          String?
  registrationDeadline DateTime
  maxStudents          Int          @default(10)
  isPublished          Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @default(now())
  enrollments          Enrollment[]
}

model Enrollment {
  id         String   @id @default(cuid())
  courseId   String
  userId     String
  status     String   @default("pending") // pending, successful
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

