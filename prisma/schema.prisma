// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  user // Người dùng mới đăng ký, chưa là học viên
  member // Học viên/member đã đăng ký khóa học
  admin // Quản trị viên
}

enum EnrollmentStatus {
  pending // Đã đăng ký, chờ thanh toán
  active // Đã thanh toán, đang học
  completed // Hoàn thành khóa
  dropped // Rút khỏi khóa
  suspended // Tạm dừng
}

enum PaymentStatus {
  pending // Chờ xác nhận
  verified // Đã xác nhận thanh toán
  completed // Hoàn thành
  failed // Thất bại
}

enum PaymentMethod {
  bank_transfer // Chuyển khoản ngân hàng
  momo // Ví Momo
  zalopay // Ví Zalopay
  cash // Tiền mặt
}

enum GreetingInputMethod {
  text
  voice
}

enum HomeworkMessageSender {
  student
  teacher
}

enum AccessTier {
  FREE
  PRO
  ULTRA
}

enum UpgradeOrderStatus {
  pending
  completed
  rejected
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                 @id @default(cuid())
  name                    String?
  phone                   String?                @unique
  email                   String                 @unique
  emailVerified           DateTime?
  image                   String?
  bio                     String?
  password                String?
  method                  String? // PPF, Beyond, Contrast
  role                    UserRole               @default(user) // user, member, or admin
  referrerId              String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @default(now())
  classActivityLastReadAt DateTime?
  activityPoints          Int                    @default(0)
  referrer                User?                  @relation("UserReferrals", fields: [referrerId], references: [id])
  referredUsers           User[]                 @relation("UserReferrals")
  accounts                Account[]
  sessions                Session[]
  assignments             Assignment[]
  homeworkSubmissions     HomeworkSubmission[]
  exerciseSubmissions     ExerciseSubmission[]
  enrollments             Enrollment[]
  dailyGreetingCheckins   DailyGreetingCheckin[]
  dailyReflections        DailyReflection[]
  speakYourselfAttempts   SpeakYourselfAttempt[]
  activityPointLogs       ActivityPointLog[]
  toeicAnswers            ToeicAnswer[]
  vocabularyTags          VocabularyTag[]
  tier                    AccessTier             @default(FREE)
  tierExpiresAt           DateTime?
  upgradeOrders           UpgradeOrder[]

  @@index([referrerId])
}

model UpgradeOrder {
  id             String             @id @default(cuid())
  userId         String
  targetTier     AccessTier
  durationMonths Int                @default(6)
  price          Int
  status         UpgradeOrderStatus @default(pending)
  referenceCode  String?
  paymentMethod  PaymentMethod?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  completedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assignment {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  filePath    String?
  method      String // PPF, Beyond, Contrast
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id               String  @id @default(cuid())
  code             String? // Mã khóa học: COURSE_001
  title            String
  description      String?
  shortDescription String?
  price            Int     @default(0) // Giá khóa (VNĐ)
  currency         String  @default("VND")

  // Thời gian khóa học
  startDate            DateTime? @default(now())
  endDate              DateTime? @default(dbgenerated("CURRENT_TIMESTAMP + INTERVAL '3 months'"))
  registrationDeadline DateTime

  // Thông tin khóa học
  totalLessons      Int     @default(0)
  completedSessions Int     @default(0) // Số buổi đã dạy xong (0-30)
  maxStudents       Int     @default(10)
  method            String? // PPF, Beyond, Contrast
  teacher           String? // Tên giáo viên

  // Trạng thái
  isPublished      Boolean @default(false)
  isActive         Boolean @default(true) // Khóa còn tuyển sinh
  galleryAnimation String  @default("vertical") // vertical, horizontal, diagonal

  // Early Bird Pricing Tiers (Configurable)
  sebDiscountPercent Int @default(30)
  ebDiscountPercent  Int @default(15)
  sebThresholdDays   Int @default(45)
  ebThresholdDays    Int @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  enrollments           Enrollment[]
  lessons               Lesson[]
  homeworks             CourseHomework[]
  exercises             CourseExercise[]
  lectureNotes          LectureNote[]
  vocabularies          VocabularyItem[]
  speakYourselfAttempts SpeakYourselfAttempt[]
  reviewImages          CourseReviewImage[]
  galleryImages         LandingGalleryImage[]  @relation("CourseGallery")
}

model CourseReviewImage {
  id           String   @id @default(cuid())
  courseId     String
  originalName String
  mimeType     String
  data         Bytes
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([courseId, displayOrder])
}

model CourseExercise {
  id                String   @id @default(cuid())
  courseId          String
  order             Int
  title             String
  description       String?
  exerciseType      String   @default("multiple_choice")
  audioFileUrl      String?
  attachmentFileUrl String?
  isDraft           Boolean  @default(false)
  sourceFormUrl     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  course      Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   ExerciseQuestion[]
  submissions ExerciseSubmission[]

  @@unique([courseId, order])
  @@index([courseId])
}

model ExerciseQuestion {
  id            String   @id @default(cuid())
  exerciseId    String
  order         Int
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String?
  correctOption String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exercise CourseExercise             @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  answers  ExerciseSubmissionAnswer[]

  @@unique([exerciseId, order])
  @@index([exerciseId])
}

model ExerciseSubmission {
  id              String   @id @default(cuid())
  exerciseId      String
  userId          String
  score           Int      @default(0)
  totalQuestions  Int
  durationSeconds Int?
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exercise CourseExercise             @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers  ExerciseSubmissionAnswer[]

  @@unique([exerciseId, userId])
  @@index([exerciseId])
  @@index([userId])
}

model ExerciseAudioFile {
  id           String   @id @default(cuid())
  originalName String
  mimeType     String
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExerciseAttachmentFile {
  id           String   @id @default(cuid())
  originalName String
  mimeType     String
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExerciseSubmissionAnswer {
  id             String   @id @default(cuid())
  submissionId   String
  questionId     String
  selectedOption String
  isCorrect      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submission ExerciseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   ExerciseQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@index([questionId])
}

model CourseHomework {
  id            String   @id @default(cuid())
  courseId      String
  title         String
  description   String?
  attachmentUrl String?
  dueDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course      Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([courseId])
  @@index([dueDate])
}

model HomeworkSubmission {
  id                String    @id @default(cuid())
  homeworkId        String
  userId            String
  note              String?
  teacherComment    String?
  studentLastReadAt DateTime?
  teacherLastReadAt DateTime?
  submittedAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  homework CourseHomework    @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages HomeworkMessage[]

  @@unique([homeworkId, userId])
  @@index([userId])
}

model HomeworkMessage {
  id           String                @id @default(cuid())
  submissionId String
  senderRole   HomeworkMessageSender
  content      String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  submission HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([createdAt])
}

model HomeworkAttachmentFile {
  id           String   @id @default(cuid())
  originalName String
  mimeType     String
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserAvatarFile {
  id           String   @id @default(cuid())
  originalName String
  mimeType     String
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Enrollment {
  id        String  @id @default(cuid())
  courseId  String
  userId    String
  studentId String? @unique // ID cá nhân (6 kí tự số) cho học viên

  // Mã tham chiếu (cho chuyển khoản)
  referenceCode String? // COURSE_ID-USER_ID

  // Trạng thái đăng ký
  status EnrollmentStatus @default(pending)

  // Thanh toán
  isPaid    Boolean   @default(false)
  paidAt    DateTime?
  paymentId String? // Reference đến Payment

  // Kết quả học tập
  completedAt    DateTime?
  dropoutReason  String? // Lý do rút khỏa (nếu có)
  attendanceRate Float     @default(0) // Tỷ lệ dự học (0-100)
  totalScore     Float? // Điểm tổng

  // Timeline
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments              Payment[]
  progress              Progress[]
  speakYourselfAttempts SpeakYourselfAttempt[]

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([status])
  @@index([referenceCode])
}

model SpeakYourselfAttempt {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  enrollmentId    String
  profilePayload  Json
  generatedScript String
  recognizedText  String
  accuracy        Int
  passed          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([enrollmentId])
  @@index([userId, courseId, createdAt])
}

model Payment {
  id            String  @id @default(cuid())
  enrollmentId  String
  referenceCode String? @unique // COURSEID-USERID
  amount        Int // Số tiền (VNĐ)
  currency      String  @default("VND")

  // Trạng thái thanh toán
  status        PaymentStatus  @default(pending)
  paymentMethod PaymentMethod?

  // Thông tin giao dịch
  bankReference   String? // Mã giao dịch ngân hàng
  transactionDate DateTime? // Ngày giao dịch thực tế
  verifiedAt      DateTime? // Lúc xác nhận thanh toán

  // Timeline
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([referenceCode])
  @@index([status])
  @@index([enrollmentId])
}

model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int // Thứ tự bài học trong khóa
  content     String? // Nội dung bài học (có thể dài)
  videoUrl    String? // URL video bài học
  duration    Int? // Thời lượng video (phút)

  // Timeline
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@index([courseId])
  @@index([order])
}

model Progress {
  id           String @id @default(cuid())
  enrollmentId String
  lessonId     String

  // Tình trạng bài học
  isCompleted Boolean @default(false)
  score       Float? // Điểm bài học (nếu có quiz)

  // Timeline
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

model LectureNote {
  id            String  @id @default(cuid())
  courseId      String
  sessionNumber Int // Buổi học từ 1-30
  driveLink     String? // Link Google Drive tài liệu
  description   String? // Mô tả tài liệu

  // Timeline
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, sessionNumber])
  @@index([courseId])
}

model DailyGreetingCheckin {
  id           String              @id @default(cuid())
  userId       String
  responseDate DateTime
  message      String
  inputMethod  GreetingInputMethod
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, responseDate])
  @@index([responseDate])
}

model DailyReflection {
  id           String   @id @default(cuid())
  userId       String
  responseDate DateTime
  message      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, responseDate])
  @@index([responseDate])
}

model ActivityPointRule {
  id          String   @id @default(cuid())
  activityKey String   @unique
  label       String
  points      Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityPointLog {
  id           String   @id @default(cuid())
  userId       String
  activityKey  String
  points       Int
  referenceKey String   @unique
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityKey])
  @@index([createdAt])
}

model VocabularyItem {
  id                String  @id @default(cuid())
  courseId          String?
  word              String
  phonetic          String?
  englishDefinition String?
  meaning           String
  example           String? @db.Text
  exampleVi         String? @db.Text
  topic             String  @default("WarmUp")
  displayOrder      Int     @default(1)
  isActive          Boolean @default(true)

  synonyms     String? @db.Text
  antonyms     String? @db.Text
  collocations String? @db.Text
  toeicTrap    String? @db.Text
  mnemonicUrl  String?

  category String @default("GENERAL")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tags   VocabularyTag[]

  @@index([courseId])
  @@index([courseId, displayOrder])
  @@index([category])
}

model VocabularyTopicConfig {
  id          String   @id @default(cuid())
  topic       String   @unique
  proFields   String?  @default("[]")
  ultraFields String?  @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([topic])
}

model VocabularyTag {
  id           String   @id @default(cuid())
  userId       String
  vocabId      String
  isLearned    Boolean  @default(false)
  isHard       Boolean  @default(false)
  isBookmarked Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary VocabularyItem @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabId])
  @@index([userId])
  @@index([vocabId])
}

// TOEIC Grammar Section
model ToeicGrammarTopic {
  id        String               @id @default(cuid())
  title     String
  subtitle  String?
  slug      String               @unique
  lessons   ToeicGrammarLesson[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model ToeicGrammarLesson {
  id                    String          @id @default(cuid())
  topicId               String
  title                 String
  order                 Int // Lesson 1, 2, ...
  content               String?         @db.Text
  accessTier            AccessTier      @default(FREE)
  theoryAccessTier      AccessTier      @default(FREE)
  explanationAccessTier AccessTier      @default(FREE)
  translationAccessTier AccessTier      @default(FREE)
  questions             ToeicQuestion[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  topic ToeicGrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([order])
}

model ToeicQuestion {
  id            String   @id @default(cuid())
  lessonId      String
  question      String   @db.Text
  optionA       String
  optionB       String
  optionC       String
  optionD       String?
  correctOption String
  explanation   String?  @db.Text
  translation   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lesson  ToeicGrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers ToeicAnswer[]

  @@index([lessonId])
}

model ToeicAnswer {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  selectedOption String // A, B, C, D
  isCorrect      Boolean
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question ToeicQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
}

model LandingNews {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model LandingGalleryImage {
  id           String   @id @default(cuid())
  courseId     String?
  section      String   @default("course") // "course" for regular gallery, "teacher" for teacher videos
  originalName String
  mimeType     String
  data         Bytes
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course Course? @relation("CourseGallery", fields: [courseId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([displayOrder])
  @@index([courseId])
  @@index([section])
}

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}
